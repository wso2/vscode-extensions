  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "copyfiles": "2.4.1",
    "typescript": "5.8.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.3",
    "ts-loader": "9.5.1",
    "css-loader": "7.1.2",
