{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "lib": ["ES2020", "DOM"],
    "paths": {
      "vscode-webview-network-bridge/webview": ["./node_modules/vscode-webview-network-bridge/dist/webview"],
      "vscode-webview-network-bridge/extension": ["./node_modules/vscode-webview-network-bridge/dist/extension"],
      "vscode-webview-network-bridge/router": ["./node_modules/vscode-webview-network-bridge/dist/router"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "build"]
}
